# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/quickbite"

# App
NODE_ENV=development
PORT=3001

# Frontend origins (for CORS + refresh cookie in production)
# Use FRONTEND_URL for a single frontend URL, or FRONTEND_URLS for comma-separated URLs.
FRONTEND_URL=http://localhost:5173
# FRONTEND_URLS=http://localhost:5173,https://your-production-frontend.vercel.app

# JWT
ACCESS_TOKEN_SECRET=your_access_token_secret_here_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_different_from_access
REFRESH_TOKEN_EXPIRES_IN=7d

# Business config
TAX_RATE=0.10
ORDER_ACCEPT_SLA_MINUTES=5
ORDER_SLA_SWEEP_MS=30000

# Optional
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret